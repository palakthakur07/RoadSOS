# ============================================================
# RoadSoS Backend — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── API Keys ─────────────────────────────────────────────────
# Google Maps Places API key (optional — OSM is used if absent)
# Get yours at: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Search Defaults ───────────────────────────────────────────
DEFAULT_RADIUS_KM=5
MAX_RESULTS=15
MAX_RADIUS_KM=25

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Logging ──────────────────────────────────────────────────
# Log levels: error | warn | info | http | debug
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=./logs
